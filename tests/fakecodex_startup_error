#!/bin/sh
# Stand-in for a codex that fails at startup (e.g. a too-old codex 400s the
# configured model). Print a colored error the way real codex does — cursor
# home + clear + SGR — then exit nonzero. Exercises the worker surfacing
# codex's OWN reason in the session's last_error instead of a bare exit code.
printf '\033[2J\033[H\033[1;31mError: model gpt-5.6-sol requires a newer version of Codex (>= 0.143.0)\033[0m\r\n'
exit 1
